    {
      "id": "inventory_turnover",
      "name": "Inventory Turnover",
      "category": "efficiency",
      "expression": "cogs / average_inventory",
      "unit": "turns",
      "variables": ["cogs", "average_inventory"],
      "variable_labels": {
        "cogs": ["cogs", "cost of goods sold", "cost of revenues"],
