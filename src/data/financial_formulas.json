  "formulas": [
    {
      "id": "revenue_growth_pct",
      "name": "Revenue Growth %",
      "category": "growth",
      "expression": "((revenue_current - revenue_previous) / revenue_previous) * 100",
      "unit": "%",
      "output_type": "percentage",
      "explanation": "Year-over-year revenue growth percentage.",
      "variables": ["revenue_current", "revenue_previous"],
      "variable_labels": {
        "revenue_current": ["revenue current", "current revenue", "revenue"],
        "revenue_previous": ["revenue previous", "prior revenue", "revenue last year"]
      },
      "aliases": ["revenue growth", "sales growth", "top line growth"]
    },
    {
      "id": "gross_profit",
      "name": "Gross Profit",
      "category": "profitability",
      "expression": "revenue - cogs",
      "unit": "currency",
      "output_type": "amount",
      "explanation": "Gross profit from revenue minus cost of revenue/COGS.",
      "variables": ["revenue", "cogs"],
      "variable_labels": {
        "revenue": ["revenue", "sales", "total revenues"],
        "cogs": ["cogs", "cost of goods sold", "cost of revenue", "cost of revenues"]
      },
      "derived_inputs": {
        "cogs": {
          "expression": "revenue - gross_profit",
          "variables": ["revenue", "gross_profit"]
        }
      },
      "aliases": ["gross profit"]
    },
    {
      "id": "cogs_amount",
      "name": "Cost of Revenue / COGS",
      "category": "profitability",
      "expression": "cogs",
      "unit": "currency",
      "output_type": "amount",
      "explanation": "Cost of revenue (COGS), directly stated or derived.",
      "variables": ["cogs"],
      "variable_labels": {
        "cogs": ["cogs", "cost of goods sold", "cost of revenue", "cost of revenues", "cost of sales", "total cost of revenue"]
      },
      "derived_inputs": {
        "cogs": {
          "expression": "revenue - gross_profit",
          "variables": ["revenue", "gross_profit"]
        }
      },
      "aliases": ["cogs", "cost of goods sold", "cost of revenue", "cost of sales"]
    },
    {
      "id": "gross_margin_pct",
      "name": "Gross Margin %",
      "category": "profitability",
      "expression": "((revenue - cogs) / revenue) * 100",
      "unit": "%",
      "output_type": "percentage",
      "explanation": "Gross margin based on revenue and COGS.",
      "variables": ["revenue", "cogs"],
      "variable_labels": {
        "revenue": ["revenue", "sales", "total revenues"],
        "cogs": ["cogs", "cost of goods sold", "cost of revenue", "cost of revenues"]
      },
      "derived_inputs": {
        "cogs": {
          "expression": "revenue - gross_profit",
          "variables": ["revenue", "gross_profit"]
        }
      },
      "aliases": ["gross margin"]
    },
    {
      "id": "operating_margin_pct",
      "name": "Operating Margin %",
      "category": "profitability",
      "expression": "(operating_income / revenue) * 100",
      "unit": "%",
      "output_type": "percentage",
      "explanation": "Operating margin as operating income over revenue.",
      "variables": ["operating_income", "revenue"],
      "variable_labels": {
        "operating_income": ["operating income", "income from operations", "ebit"],
        "revenue": ["revenue", "sales", "total revenues"]
      },
      "aliases": ["operating margin", "ebit margin"]
    },
    {
      "id": "net_margin_pct",
      "name": "Net Margin %",
      "category": "profitability",
      "expression": "(net_income / revenue) * 100",
      "unit": "%",
      "output_type": "percentage",
      "explanation": "Net margin as net income over revenue.",
      "variables": ["net_income", "revenue"],
      "variable_labels": {
        "net_income": ["net income", "net profit", "profit after tax"],
        "revenue": ["revenue", "sales", "total revenues"]
      },
      "aliases": ["net margin", "profit margin"]
    },
    {
      "id": "ebitda_margin_pct",
      "name": "EBITDA Margin %",
      "category": "profitability",
      "expression": "(ebitda / revenue) * 100",
      "unit": "%",
      "variables": ["ebitda", "revenue"],
      "variable_labels": {
        "ebitda": ["ebitda"],
        "revenue": ["revenue", "sales", "total revenues"]
      },
      "aliases": ["ebitda margin"]
    },
    {
      "id": "current_ratio",
      "name": "Current Ratio",
      "category": "liquidity",
      "expression": "current_assets / current_liabilities",
      "unit": "ratio",
      "output_type": "ratio",
      "explanation": "Current assets divided by current liabilities.",
